#!/bin/bash

# Read ANTHROPIC_API_KEY from ~/.zshrc
if grep -q 'ANTHROPIC_API_KEY' ~/.zshrc; then
    export ANTHROPIC_API_KEY=$(grep 'ANTHROPIC_API_KEY' ~/.zshrc | grep -o '"[^"]*"' | tail -1 | tr -d '"')
fi

# Also try sourcing zshrc if the above didn't work
if [ -z "$ANTHROPIC_API_KEY" ]; then
    source ~/.zshrc 2>/dev/null || true
fi

# Change to the notebook-webapp directory
cd /Users/dkSusKro/Documents/claude-projects/notebook-transcription/notebook-webapp

PYTHON=/Users/dkSusKro/Documents/claude-projects/notebook-transcription/notebook-webapp/venv/bin/python3

# Start uvicorn in the background
$PYTHON -m uvicorn main:app --port 8000 --loop asyncio --http h11 &>/tmp/notebook-app.log &
UVICORN_PID=$!
echo $UVICORN_PID > /tmp/notebook-app.pid

# Wait for the server to start
sleep 4

# Open the browser
open http://localhost:8000
